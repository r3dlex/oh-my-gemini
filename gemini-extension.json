{
  "$schema": "https://raw.githubusercontent.com/google-gemini/gemini-cli/main/packages/cli/schemas/gemini-extension.json",
  "name": "oh-my-gemini",
  "version": "1.0.0",
  "description": "Multi-agent orchestration for Gemini CLI with OMG branding, team runtime scaffolding, and OMP compatibility aliases.",
  "author": "jjongguet",
  "license": "MIT",
  "homepage": "https://github.com/jjongguet/oh-my-gemini",
  "sourceUrl": "https://github.com/jjongguet/oh-my-gemini",
  "contextFileName": "GEMINI.md",
  "mcpServers": {
    "omp_cli_tools": {
      "command": "oh-my-gemini",
      "args": [
        "tools",
        "serve"
      ],
      "transport": "stdio",
      "description": "oh-my-gemini CLI tools MCP server (file/git/http/process)"
    }
  }
}
